<Window x:Class="GameDeck.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameDeck Settings" Width="520" Height="480"
        Icon="pack://application:,,,/Assets/app.ico"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <TabControl Margin="8">
        <TabItem Header="General">
            <StackPanel Margin="14">
                <CheckBox x:Name="StartWithWindowsBox" Content="Start with Windows" />
                <CheckBox x:Name="AnimationsBox" Content="Overlay animations (fade in and out)"
                          Margin="0,12,0,0" />
            </StackPanel>
        </TabItem>

        <TabItem Header="Overlay">
            <StackPanel Margin="14">
                <TextBlock Text="Opacity" FontWeight="SemiBold" />
                <DockPanel Margin="0,4,0,0">
                    <TextBlock x:Name="OpacityLabel" DockPanel.Dock="Right" Width="44"
                               TextAlignment="Right" VerticalAlignment="Center" />
                    <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0"
                            TickFrequency="0.05" IsSnapToTickEnabled="True" />
                </DockPanel>

                <TextBlock Text="Auto-hide" FontWeight="SemiBold" Margin="0,16,0,0" />
                <ComboBox x:Name="AutoHideBox" Width="200" HorizontalAlignment="Left"
                          Margin="0,4,0,0" />

                <TextBlock Text="Corner" FontWeight="SemiBold" Margin="0,16,0,0" />
                <UniformGrid Rows="2" Columns="2" Width="180" HorizontalAlignment="Left"
                             Margin="0,4,0,0">
                    <Button x:Name="CornerTL" Content="Top left" Margin="2" Padding="0,4" />
                    <Button x:Name="CornerTR" Content="Top right" Margin="2" Padding="0,4" />
                    <Button x:Name="CornerBL" Content="Bottom left" Margin="2" Padding="0,4" />
                    <Button x:Name="CornerBR" Content="Bottom right" Margin="2" Padding="0,4" />
                </UniformGrid>

                <TextBlock Foreground="Gray" Margin="0,16,0,0" TextWrapping="Wrap"
                           Text="Tip: press Ctrl+Alt+I in-game to make the overlay draggable and drop it exactly where you want it. Corners keep their position across resolution changes." />
            </StackPanel>
        </TabItem>

        <TabItem Header="Hotkeys">
            <StackPanel Margin="14">
                <TextBlock x:Name="RecordHint" Foreground="Gray" TextWrapping="Wrap"
                           Text="Click Record, then press the new combination. Esc cancels. Combos need at least one modifier (Ctrl, Alt, Shift, Win)." />
                <ItemsControl x:Name="HotkeyList" Margin="0,10,0,0" />
            </StackPanel>
        </TabItem>

        <TabItem Header="Media">
            <StackPanel Margin="14">
                <TextBlock Text="Media source" FontWeight="SemiBold" />
                <ComboBox x:Name="SourceBox" Width="280" HorizontalAlignment="Left"
                          Margin="0,4,0,0" />
                <TextBlock Foreground="Gray" Margin="0,10,0,0" TextWrapping="Wrap"
                           Text="Automatic follows whatever Windows says is playing. Pinning a source keeps GameDeck locked to it even when other apps play sounds." />
            </StackPanel>
        </TabItem>

        <TabItem Header="Bridge">
            <StackPanel Margin="14">
                <TextBlock x:Name="BridgeStatusText" FontWeight="SemiBold" />
                <TextBlock Text="Extension token" Margin="0,16,0,4" />
                <DockPanel>
                    <Button x:Name="CopyTokenButton" Content="Copy" DockPanel.Dock="Right"
                            Margin="6,0,0,0" Padding="12,2" />
                    <TextBox x:Name="TokenBox" IsReadOnly="True" FontFamily="Consolas" />
                </DockPanel>
                <TextBlock x:Name="BridgePortText" Foreground="Gray" Margin="0,10,0,0" />
                <TextBlock Foreground="Gray" Margin="0,10,0,0" TextWrapping="Wrap"
                           Text="Paste the token into the GameDeck Companion extension's options page. Everything stays on this machine." />
            </StackPanel>
        </TabItem>

        <TabItem Header="About">
            <StackPanel Margin="14">
                <TextBlock x:Name="VersionText" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Margin="0,6,0,0"
                           Text="Control your music and skip YouTube ads without leaving your game." />
                <TextBlock Margin="0,12,0,0">
                    <Hyperlink x:Name="GithubLink">github.com/Land784/GameDeck</Hyperlink>
                </TextBlock>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
