{
  "manifest_version": 3,
  "name": "GameDeck Companion",
  "version": "1.0.0",
  "description": "Lets the GameDeck desktop app show YouTube ad status in-game and skip ads with a hotkey.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://www.youtube.com/*"],
  "background": { "service_worker": "worker.js" },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
